<% layout('layout/boilerplate') %>

<div class="show-container">

    <h2 class="show-title col-6"><%= listing.title %></h2>

    <div class="show-card">

        <img
            src="<%= listing.image.url %>"
            alt="<%= listing.title %>"
            class="show-img"
        >

        <div class="show-body">
            <div class="owner-badge mb-3">
               Hosted by <strong><%= listing.owner.username %></strong>
            </div>


            <p class="show-price ">
                ₹ <%= listing.price.toLocaleString("en-IN") %>/night
            </p>

            <p class="show-description">
                <%= listing.description %>
            </p>

            <div class="show-location ">
                📍 <%= listing.location %>, <%= listing.country %>
            </div>


            <% if (currUser && listing.owner._id.equals(currUser._id)) { %>
            <div class="show-actions">

                <a href="/listings/<%= listing._id %>/edit"
                   class="edit-btn">
                    Edit
                </a>

                <form method="post"
                      action="/listings/<%= listing._id %>?_method=DELETE">

                    <button class="delete-btn">
                        Delete Listing
                    </button>

                </form>

            </div>
            <% } %>

            <% if(currUser && !listing.owner._id.equals(currUser._id)){ %>

            <a href="/bookings/<%= listing._id %>/book"
             class="btn btn-danger">
   
                Book Now

            </a>

           <% } %>

        </div>

    </div>


    <!-- ADD REVIEW FORM -->
<% if(currUser) { %>
<div class="review-box">

    <h3 class="review-title">Leave a Review</h3>

    <form method="POST" action="/listings/<%= listing._id %>/reviews">

        <div class="review-input-group">
            <label>Your Experience</label>

            <textarea
                name="review[comment]"
                placeholder="Share your thoughts about this place..."
                required></textarea>
        </div>


        <div class="review-input-group">
            <label>Rating</label>
<div class="star-rating">

    <input type="radio" id="star5" name="review[rating]" value="5">
    <label for="star5">★</label>

    <input type="radio" id="star4" name="review[rating]" value="4">
    <label for="star4">★</label>

    <input type="radio" id="star3" name="review[rating]" value="3">
    <label for="star3">★</label>

    <input type="radio" id="star2" name="review[rating]" value="2">
    <label for="star2">★</label>

    <input type="radio" id="star1" name="review[rating]" value="1" required>
    <label for="star1">★</label>

</div>
        </div>


        <button class="review-btn">
            Submit Review
        </button>

    </form>

</div>
<% } %>


<!-- DISPLAY REVIEWS -->

<div class="reviews-section">

  <h3>Reviews</h3>

  <% if(listing.reviews.length === 0){ %>

    <p>No reviews yet. Be the first to review!</p>

  <% } else { %>

    <div class="reviews-container">

      <% listing.reviews.forEach(review => { %>

        <div class="review-card">

          <h5 class="review-author">
            👤 <%= review.author.username %>
          </h5>

          <div class="rating">

            <% for(let i = 1; i <= 5; i++) { %>

              <% if(i <= review.rating) { %>

                <span class="filled-star">★</span>

              <% } else { %>

                <span class="empty-star">☆</span>

              <% } %>

            <% } %>

          </div>

          <p class="comment">
            <%= review.comment %>
          </p>

          <% if (currUser && review.author._id.equals(currUser._id)) { %>

            <form method="POST"
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

              <button class="btn btn-sm btn-dark">
                Delete
              </button>

            </form>

          <% } %>

        </div>

      <% }) %>

    </div>

  <% } %>

</div>



