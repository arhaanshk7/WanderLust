<% layout("layout/boilerplate") %>

<h2>My Bookings</h2>

<% if(bookings.length === 0){ %>

    <p>You have no bookings yet.</p>

<% } else { %>

    <div class="row">

    <% bookings.forEach(booking => { %>

        <div class="col-md-4">

            <div class="card mb-3">

                <img src="<%= booking.listing.image.url %>" class="card-img-top">

                <div class="card-body">

                    <h5>
                        <%= booking.listing.title %>
                    </h5>

                    <p>
                        ₹<%= booking.totalPrice %>
                    </p>

                    <p>
                        <%= booking.checkIn.toDateString() %> →
                        <%= booking.checkOut.toDateString() %>
                    </p>

                    <form  method="get" action="/bookings/<%= booking._id %>/cancel">
                        
                    <button>
                        Cancel Booking
                    </button>
                    
                    <a href="/chat/<%= booking.listing._id %>/<%= booking.listing.owner._id %>"
                     class="btn btn-primary ms-2">
                       Chat with Host
                    </a>

                    </form>

                </div>

            </div>

        </div>

    <% }) %>

    </div>

<% } %>